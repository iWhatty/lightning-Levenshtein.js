{
    "name": "lightning-levenshtein",
    "version": "0.0.1",
    "description": "Blazing-fast Levenshtein distance with bit-parallel Myers algorithm and early exits.",
    "main": "./src/index.js",
    "module": "./src/index.js",
    "browser": "./dist/lightning-levenshtein.min.js",
    "type": "module",
    "exports": {
        ".": "./dist/lightning-levenshtein.min.js",
        "./v2": "./dist/lightning-levenshtein-v2.min.js"
    },
    "files": [
        "dist/lightning-levenshtein.min.js",
        "dist/lightning-levenshtein-v2.min.js",
        "LICENSE.md",
        "README.md"
    ],
    "scripts": {
        "build": "node ./build-gcc.mjs",
        "build:v2": "node ./build-gcc-bolt.mjs",
        "build:all": "npm run build && npm run build:v2",
        "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
        "html": "http-server . -p 8000 -c-1",
        "html:open": "start http://localhost:8000/bench/benchmark.html",
        "bench": "node bench/bench.js",
        "bench:peq": "node ./bench/peq-benchmark.mjs",
        "bench:myersx": "node ./bench/myers-x-variants/run-bench.js",
        "bench:myers32": "node ./bench/myers32-variants/run-bench.js",
        "bench:small": "node ./bench/small_kernals/bench-2x-small.js",
        "bench:packages": "node ./bench/packages/run-bench.js",
        "bench:packages:table": "node ./bench/packages/render-readme-table.js",
        "bench:packages:chart": "node ./bench/packages/render-relative-bar-chart.js && npm run bench:packages:linechart && npm run bench:packages:percent",
        "bench:packages:linechart": "node ./bench/packages/render-readme-line-chart.js",
        "bench:packages:percent": "node ./bench/packages/render-readme-relative-fastest-chart.js",
        "bench:packages:all": "node ./bench/packages/run-bench.js && node ./bench/packages/render-readme-table.js && node ./bench/packages/render-readme-chart.js",
        "codegen:myers32:a": "node ./codegen/tools/generateMyers32-A.cjs",
        "codegen:myers32:b": "node ./codegen/tools/generateMyers32-B.cjs",
        "codegen:myers32": "npm run codegen:myers32:a && npm run codegen:myers32:b"
    },
    "keywords": [
        "levenshtein",
        "distance",
        "fastest",
        "fast",
        "fuzzy",
        "string",
        "search",
        "algorithm",
        "similarity",
        "comparison",
        "bit-parallel",
        "matching",
        "browser",
        "node",
        "js"
    ],
    "author": "Dr.Watt",
    "license": "Dr.Watt",
    "devDependencies": {
        "benchmark": "^2.1.4",
        "fast-levenshtein": "^3.0.0",
        "fastest-levenshtein": "^1.0.16",
        "http-server": "^14.1.1",
        "jest": "^29.0.0",
        "js-levenshtein": "^1.1.6",
        "leven": "^3.1.0",
        "levenshtein-edit-distance": "^3.0.1"
    },
    "directories": {
        "test": "test"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/iWhatty/lightning-Levenshtein.js.git"
    },
    "bugs": {
        "url": "https://github.com/iWhatty/lightning-Levenshtein.js/issues"
    },
    "homepage": "https://github.com/iWhatty/lightning-Levenshtein.js#readme"
}